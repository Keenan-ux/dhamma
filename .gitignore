node_modules/
dist/
.vite/
.env
.env.local
.env.*.local
*.log
.DS_Store
Thumbs.db
.fly/

# Postgres data lives on a separate Fly volume — never committed
server/data/

# BGE-M3 weights downloaded by @xenova/transformers at runtime/build time
.model-cache/

# Debug / one-shot dump artifacts (corpus introspection, SC parallel
# audits, local cache snapshots). Regenerable; never committed.
/corpus_dump.json
/sc_parallels.json
/sc_relationships.json
/DevDhamma.cache_corpus.json

# Per-project Claude Code state (settings.local.json, agents, etc.).
# Track shared skills (e.g. the coordinator role) so they survive clones and
# reach the second collaborator; keep the rest of .claude/ local-only.
.claude/*
!.claude/skills/

# Dictionary ingest source archives (regenerable via curl from the
# linked GitHub release). Stored locally for re-runs but never
# committed; the ingest script header documents the download URL.
/scripts/ingest/abt.tar
/scripts/ingest/abt.tar.zst
/scripts/ingest/CPED.csv
/scripts/ingest/.cache/

# Xenova v2 vs v3 smoke-test scratch (~250 MB of node_modules
# across two runner subdirs). The driver scripts themselves are
# fine to keep but the installed deps + per-version model caches
# shouldn't be tracked.
/scripts/xenova-smoke/node_modules/
/scripts/xenova-smoke/*/node_modules/
/scripts/xenova-smoke/*/.cache/
/scripts/xenova-smoke/queries.ndjson

# Python build artifacts from the gloss-injection re-embed pipeline.
__pycache__/
*.pyc

# Throwaway probe scripts (per-session diagnostics, ad-hoc DB sizing
# probes, smoke tests). The real backfill / migrate / reindex tools
# in scripts/ingest/ are committed; the probe-* scripts are local
# scratch only.
/scripts/ingest/probe-*.mjs
