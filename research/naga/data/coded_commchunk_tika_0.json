 {"id": "cst-s0104t.nrf-7_p149", "referent": "serpent", "claim_bearing": false, "facet": null, "claim": null, "note": "nāga-yakkha-rakkhasa-pisācādito — danger from nāgas, yakkhas, rakkhasas, pisācas; nāga among threatening beings, passing"},
 {"id": "cst-s0105t.nrf-13_p024", "referent": "serpent", "claim_bearing": false, "facet": null, "claim": null, "note": "avasesa-nāga-supaṇṇa-nerayikādi-sattaloko — remaining beings: nāgas, supaṇṇas, hell-beings; classification list, passing"},
 {"id": "cst-s0105t.nrf-13_p039", "referent": "serpent", "claim_bearing": false, "facet": null, "claim": null, "note": "Varuṇa-nāgarājānaṃ — Vidhura addressing Varuṇa the nāga-king; named nāga-king, but the line only reports an address (no ontological claim). samannāgama in same row is nonlexical"},
 {"id": "cst-s0105t.nrf-16_p056", "referent": "serpent", "claim_bearing": true, "facet": "realm_habitat", "claim": "a nāga-anthill (nāgavammika) is the dwelling of nāgas; used as image of the self-empty body", "note": "nāgānaṃ nivāso vammiko nāgavammiko; nāgas' dwelling-place — habitat"},
 {"id": "cst-s0105t.nrf-24_p004", "referent": "serpent", "claim_bearing": true, "facet": "power", "claim": "this is said of mighty nāgas: by nāga-iddhi one stays in one's own serpent-species (at rebirth, death, mating, shedding skin), not a different-species form", "note": "mahiddhike nāge sandhāya; uraga-jāti; nāga shapeshift-power + species-bound transformation"},
 {"id": "cst-s0105t.nrf-27_p004", "referent": "serpent", "claim_bearing": false, "facet": null, "claim": null, "note": "deva-nāga-yakkha-gandhabba list of beings; passing mention"},
