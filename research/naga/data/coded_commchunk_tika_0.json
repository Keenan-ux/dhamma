 {"id": "cst-s0105t.nrf-6_p012", "referent": "serpent", "claim_bearing": true, "facet": "realm_habitat", "claim": "the nāga-realm (nāgabhavana) is [reckoned as] a nāga-circle/domain, like the Mahiṃsaka domain", "note": "nāgabhavanaṃ nāgamaṇḍalaṃ; nāgabhavana = nāga world/realm — habitat. (nāgamaṇḍala here = nāga-domain, not snake-charm)"},
 {"id": "cst-s0105t.nrf-73_p007", "referent": "elephant", "claim_bearing": false, "facet": null, "claim": null, "note": "sīha-saddūla-nāgādyā … pume seṭṭhattha — grammatical list of masculine 'best' words; nāga = bull-elephant alongside lion/tiger"},
